<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://android.com"
    android:id="@+id/wordCardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Текстовый блок (Слово + Перевод) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvGerman"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Das Auto"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#212529"/>

            <TextView
                android:id="@+id/tvRussian"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Автомобиль"
                android:textSize="14sp"
                android:textColor="#6C757D"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Кнопка динамика для озвучки -->
        <ImageButton
            android:id="@+id/btnSpeak"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_btn_speak_now"
            android:contentDescription="Прослушать"
            app:tint="#0D6EFD" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
