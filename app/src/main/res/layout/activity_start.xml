<?xml version="1.0" encoding="utf-8"?>
<!-- Добавлен скролл-контейнер для маленьких экранов -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://android.com"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Крупное название приложения -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Zettel"
            android:textColor="#1A237E"
            android:textSize="40sp"
            android:textStyle="bold" />

        <!-- Иконка блокнота -->
        <ImageView
            android:id="@+id/ivAppLogo"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="#3F51B5"
            android:contentDescription="Zettel" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Выберите уровень сложности:"
            android:textSize="16sp"
            android:textColor="#5C6BC0"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- 4 кнопки уровней сложности -->
        <Button
            android:id="@+id/btnLevelA1"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="12dp"
            android:text="Уровень A1 (Начальный)"
            android:textSize="16sp"
            android:backgroundTint="#3F51B5"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnLevelA2"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="12dp"
            android:text="Уровень A2 (Элементарный)"
            android:textSize="16sp"
            android:backgroundTint="#3F51B5"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnLevelB1"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="12dp"
            android:text="Уровень B1 (Средний)"
            android:textSize="16sp"
            android:backgroundTint="#3F51B5"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnLevelB2"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="24dp"
            android:text="Уровень B2 (Продвинутый)"
            android:textSize="16sp"
            android:backgroundTint="#3F51B5"
            android:textColor="#FFFFFF" />
        <!-- Кнопка запуска тестирования -->
        <Button
            android:id="@+id/btnStartQuiz"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="32dp"
            android:text="Режим тестирования"
            android:textSize="16sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF" />


        <!-- Разделитель -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="24dp" />

        <!-- Кнопка перехода к темам -->
        <Button
            android:id="@+id/btnOpenTopics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Темы и добавление слов"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>

