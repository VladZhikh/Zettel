<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://android.com"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#F8F9FA"
    android:padding="24dp">

    <!-- КНОПКА НАЗАД  -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="start"
        android:layout_marginBottom="16dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Назад к темам"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="#212529" />

    <!-- карточка слова -->
    <LinearLayout
        android:id="@+id/wordCard"
        android:layout_width="300dp"
        android:layout_height="350dp"
        android:background="@android:color/white"
        android:elevation="6dp"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="40dp">

        <!-- Немецкое слово -->
        <TextView
            android:id="@+id/tvGermanWord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Der Hund"
            android:textColor="#212529"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- Кнопка динамика внутри карточки -->
        <ImageButton
            android:id="@+id/btnSpeakCard"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_btn_speak_now"
            android:contentDescription="Прослушать еще раз"
            app:tint="#0D6EFD" />

        <!-- Перевод  -->
        <TextView
            android:id="@+id/tvTranslation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Собака"
            android:textColor="#6C757D"
            android:textSize="20sp"
            android:layout_marginTop="16dp"
            android:visibility="invisible" />

    </LinearLayout>

    <!-- Зеленая кнопка "знаю"-->
    <Button
        android:id="@+id/btnKnow"
        android:layout_width="200dp"
        android:layout_height="55dp"
        android:text="Знаю"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2E7D32" />

</LinearLayout>
